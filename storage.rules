rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Posts: public read, authenticated write (images/videos only, max 100MB)
    match /posts/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 100 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
    }
    // Stories: public read, authenticated write (24h media)
    match /stories/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 100 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
    }
    // Stays: public read, admin-only write (images up to 20MB each)
    match /stays/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == "ratsthh1997@gmail.com"
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // Trips: public read, admin-only write
    match /trips/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == "ratsthh1997@gmail.com"
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
