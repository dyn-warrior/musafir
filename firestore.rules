rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Posts: anyone can read, authenticated users can create or like/save (update likedBy/likes)
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      // Author can update anything; any auth user can update likes/likedBy/comments counts
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorUid;

      // Comments subcollection: public read, auth create
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
      }
    }

    // Users: anyone can read profiles, but only the owner can write
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Stories: public read, authenticated users can post (24h stories)
    match /stories/{storyId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorUid;
      // Allow auth users to like/unlike and update comment counts
      allow update: if request.auth != null;

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
      }
    }

    // Destinations, stays, festivals: public read, admin write
    match /destinations/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "ratsthh1997@gmail.com";
    }
    match /stays/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "ratsthh1997@gmail.com";
    }
    match /festivals/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "ratsthh1997@gmail.com";
    }

    // Trip packages: public read, admin write
    match /tripPackages/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "ratsthh1997@gmail.com";
    }

    // Go-out requests: public read, authenticated create
    match /goOutRequests/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorUid;
    }

    // Community groups: public read, authenticated create, member-only updates
    match /communityChats/{chatId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.memberUids;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;

      match /messages/{msgId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/communityChats/$(chatId)).data.memberUids;
      }
    }
    // Direct Messages
    match /directMessages/{dmId} {
      // Allow any signed-in user to read (needed: getDoc to check existence before creating)
      allow read: if request.auth != null;
      // Create: requester must be in the participant list of the new doc
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participantUids;
      // Update/delete: only existing participants
      allow update, delete: if request.auth != null
        && request.auth.uid in resource.data.participantUids;

      match /messages/{msgId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
    }

  }
}
